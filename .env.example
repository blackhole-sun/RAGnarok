# ============================================================
# Rangarok RAG — Environment Variables Reference
# ============================================================
# Copy backend/.env.example → backend/.env
# Copy frontend/.env.local.example → frontend/.env.local
# Fill in all values before starting the app.

# ---- BACKEND (backend/.env) --------------------------------

# Supabase
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Found in: Supabase Dashboard → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# OpenAI
OPENAI_API_KEY=sk-...
# Leave empty on first run — the app will create a vector store and print the ID.
# After first upload, set this to the printed ID to reuse the same store.
OPENAI_VECTOR_STORE_ID=

# LangSmith (optional but recommended)
# Create account at: https://smith.langchain.com
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=rangarok-rag-module-1
LANGSMITH_TRACING_V2=true

# App
FRONTEND_ORIGIN=http://localhost:5173

# ---- FRONTEND (frontend/.env.local) ------------------------

# Supabase (public anon key — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API
VITE_API_BASE_URL=http://localhost:8000
